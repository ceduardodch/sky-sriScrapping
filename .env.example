# Credenciales SRI Ecuador
SRI_RUC=1234567890001
SRI_PASSWORD=tu_clave_aqui

# Browser (false = con ventana visible para depurar, true = sin ventana)
HEADLESS=false
BROWSER_CHANNEL=chrome
BROWSER_EXECUTABLE_PATH=

# Fecha del reporte (dejar vacío = ayer automáticamente)
# Formato: YYYY-MM-DD
REPORT_DATE=

# Timeouts en milisegundos
PAGE_TIMEOUT_MS=60000
DOWNLOAD_TIMEOUT_MS=120000

# Reintentos ante errores de red
RETRY_ATTEMPTS=3

# ── API push (opcional — si no está configurado, guarda XML en disco) ──────────
# URL de la SRI Comprobantes API
API_URL=http://localhost:8000
# ADMIN_API_KEY de la API (el mismo valor de ADMIN_API_KEY en docker-compose)
API_KEY=
# ID del tenant registrado en la API para este RUC
API_TENANT_ID=

# ── API / worker nativos ──────────────────────────────────────────────────────
# BD de control (tenants, auth, scrape_logs)
DATABASE_URL=postgresql+asyncpg://sri:cambia_esta_clave@127.0.0.1:5432/sri_db
# Data stores por nombre. `default` cae a DATABASE_URL si no se define.
# Formato JSON:
# DATA_DATABASE_URLS={"default":"postgresql+asyncpg://.../sri_db","clientes_secundarios":"postgresql+asyncpg://.../sri_clientes"}
DATA_DATABASE_URLS={}
INTERNAL_API_URL=http://127.0.0.1:8000
WORKER_RUNTIME_ROOT=runtime

# ── Variables compartidas con Docker Compose (api/ + worker) ─────────────────
# Contraseña de PostgreSQL
DB_PASSWORD=cambia_esta_clave

# API key de administrador (genera con: python -c "import secrets; print(secrets.token_urlsafe(32))")
ADMIN_API_KEY=

# Clave Fernet para cifrar contraseñas SRI (genera con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FERNET_KEY=
